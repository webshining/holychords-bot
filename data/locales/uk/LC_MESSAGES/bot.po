msgstr "Оберіть пісню:"

#: app/handlers/users/search.py:30
msgid "Enter song name:"
msgstr "Введіть назву пісні:"

#: app/handlers/users/search.py:47
msgid "A song with this name was not found, try another:"
msgstr "Пісню з такою назвою не було знайдено, спробуйте іншу:"

#: app/handlers/users/song.py:22
msgid "Looks like the song has no lyrics"
msgstr "Схоже, що на ресурсі немає слів для цієї пісні"

#: app/handlers/users/song.py:34
msgid "Looks like the songs are out of memory or you used /cancel"
msgstr "Схоже, в памʼяті немає пісень або ви використали /cancel"

#: app/handlers/users/song.py:62
msgid "Looks like there’s no music on the resource for this song"
msgstr "Схоже, що на ресурсі немає музики для цієї пісні"

